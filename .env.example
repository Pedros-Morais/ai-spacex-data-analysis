# Sobrescreva qualquer Settings via variáveis de ambiente com prefixo LAUNCH_.
# Exemplos:
# LAUNCH_TARGET=landing_success      # alvo alternativo (recuperação do 1º estágio)
# LAUNCH_SELECTION_METRIC=pr_auc     # selecionar o melhor modelo por PR-AUC
# LAUNCH_USE_SMOTE=true              # ativar SMOTE no fold de treino
# LAUNCH_TUNE_HYPERPARAMETERS=true   # busca de hiperparâmetros (Randomized/GridSearchCV)
# LAUNCH_SEARCH_STRATEGY=random      # "random" (padrão) ou "grid"
# LAUNCH_SEARCH_N_ITER=15            # candidatos amostrados na busca randômica
# LAUNCH_SEED=42
# LAUNCH_CV_FOLDS=5
# LAUNCH_TEST_SIZE=0.2
